main() {
    int age = int(read("Enter an integer (e.g. 25): "));
    print("Next year: " + (age + 1));

    dec price = dec(read("Enter a decimal (e.g. 9.99): "));
    print("Double: " + (price * 2.0));

    txt name = read("Enter your name: ");
    print("Hello, " + name + "!");

    txt empty = read("Press Enter to continue: ");
    print("Empty input returned: '" + empty + "'");
}
