main() {
    let age = read("Enter an integer (e.g. 25): ");
    print("Next year: " + (age + 1));

    let price = read("Enter a decimal (e.g. 9.99): ");
    print("Double: " + (price * 2.0));

    let name = read("Enter your name: ");
    print("Hello, " + name + "!");

    let empty = read("Press Enter to continue: ");
    print("Empty input returned: '" + empty + "'");
}
