int add(int a, int b) {
    return a + b;
}

int factorial(int n) {
    if n <= 1 {
        return 1;
    }
    return n * factorial(n - 1);
}

void greet(txt name) {
    print("Hello, " + name);
}

int fib(int n) {
    if n <= 1 {
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}

main() {
    print(add(5, 3));
    print(factorial(5));
    greet("MLang");
    print(fib(6));
}
